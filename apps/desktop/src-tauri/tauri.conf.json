{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codex-helper",
  "version": "0.19.0",
  "identifier": "com.latias94.codex-helper.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm tauri:build:assets",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "codex-helper",
        "width": 1280,
        "height": 820,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Latias94",
    "externalBin": [
      "sidecars/codex-helper"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
