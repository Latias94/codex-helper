CODEX_HELPER_VERSION=latest
CODEX_HELPER_IMAGE=ghcr.io/latias94/codex-helper-server

# Bind proxy traffic to LAN by default so other machines can point Codex at the NAS.
CODEX_HELPER_PROXY_BIND=0.0.0.0

# Keep admin local to the NAS host by default. Use a firewall or Tailscale ACL before exposing it.
CODEX_HELPER_ADMIN_BIND=127.0.0.1
CODEX_HELPER_ADMIN_TOKEN=change-this-long-random-token

# Used by deploy/container/config.toml. Replace this if your config uses another env var.
OPENAI_API_KEY=replace-me

RUST_LOG=info
